func getLayer(layer) {
    let base = 20
    let diff = 8
    return `rgb(${20 + layer * diff}, ${20 + layer * diff}, ${20 + layer * diff})`
}

func getColor(r, g, b) {
    return `rgb(${r}, ${g}, ${b})`
}

func getPadding(rem) {
    return rem + "rem"
}

// def l0: { getLayer(0) }
def l0: rgb(20, 20, 20);
def l1: getLayer(1);
def l2: getLayer(2);
def l3: getLayer(3);
def inlinePad: getPadding(4);
def blockPad: getPadding(1.6);
def pad: getPadding(4) getPadding(1.6) getPadding(4) getPadding(4);

.module{
    padding: 1.6rem;
    margin: 1.6rem;
    background: var(--l1);
    text-align: center;
    border-radius: 0.4rem;
    cursor: pointer;

    :hover{
        background: var(--l2);
    }

    .title{
        font-size: 1.5rem;
        font-weight: 600;
    }

    .description{
        opacity: 0.75;
    }
}