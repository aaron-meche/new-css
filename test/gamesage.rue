func getLayer(layer) {
    let hue = 222;
    let sat = 22;
    let satDiff = 5
    let bright = 10;
    let brightDiff = 5
    // return "rgb(0,0,0)"
    return `hsl(${hue}, ${sat + satDiff * layer}%, ${bright + brightDiff * layer}%)`
    // return getColor(hue, sat + satDiff * layer, bright + brightDiff * layer)
}

def bg: getLayer(0);
// def l05: getLayer(0.5);
def l1: getLayer(1);
def l2: getLayer(2);
