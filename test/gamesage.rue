def hue: 240;
def sat: 8%;
def strt: 94%;
def diff: -6%;

def accent: hsl(var(--hue), 48%, 48%);
def accent-transparent: hsl(var(--hue), 48%, 48%, 40%);
def true-accent: hsl(255, 89%, 64%);
def contrast: hsl(var(--hue), 0%, calc(100% - var(--strt)));
def contrast-transparent: hsl(var(--hue), 0%, 92%, 40%);
def bg: hsl(var(--hue), var(--sat), calc(var(--strt) + (0 * var(--diff))));
def bg-transparent: hsl(var(--hue), var(--sat), calc(var(--strt) + (0 * var(--diff))), 40%);
def l05: hsl(var(--hue), var(--sat), calc(var(--strt) + (0.5 * var(--diff))));
def l1: hsl(var(--hue), var(--sat), calc(var(--strt) + (1 * var(--diff))));
def l2: hsl(var(--hue), var(--sat), calc(var(--strt) + (2 * var(--diff))));
def l3: hsl(var(--hue), var(--sat), calc(var(--strt) + (3 * var(--diff))));
def l4: hsl(var(--hue), var(--sat), calc(var(--strt) + (4 * var(--diff))));
def l5: hsl(var(--hue), var(--sat), calc(var(--strt) + (5 * var(--diff))));
def l6: hsl(var(--hue), var(--sat), calc(var(--strt) + (6 * var(--diff))));
def green: hsl(120, 40%, 80%);
def red: hsl(0, 40%, 80%);

def inline-moat: 8vw;

body{
    height: 100%;
    margin: 0;
    background: var(--bg);
    font-size: 1rem;
    font-family: Figtree;
    color: var(--contrast);
}

a,button,input{
    all: unset;
    display: block;
}

.horizontal-scroll{
    display: flex;
    background: none;
    overflow-x: scroll;
    overflow-y: hidden;
    font-size: 0;
    white-space: nowrap;
}
.horizontal-scroll > *{
    display: inline-block;
    font-size: initial;
}
.horizontal-scroll::-webkit-scrollbar{
    display: none;
}
.horizontal-scroll::-moz-progress-bar{
    display: none;
}


/* Red Alert */
.alert{
    padding: 0.8rem 1.2rem;
    margin-bottom: 1.2rem;
    background: hsl(0, 50%, 20%, 50%);
    outline: solid 2pt hsl(0, 50%, 40%);
    border-radius: 0.4rem;
    line-height: 1.5;
}

/* Orange Warning */
.warning{
    padding: 0.8rem 1.2rem;
    margin-bottom: 1.2rem;
    background: hsl(30, 50%, 20%, 50%);
    outline: solid 2pt hsl(30, 50%, 40%);
    border-radius: 0.4rem;
    line-height: 1.5;
}